# ============================================
# PataCerta — STAGE Environment Variables
# Copy to .env.stage in Dokploy and fill real secrets.
# DO NOT commit the real .env.stage — only this example.
# ============================================

# ---- General ----
NODE_ENV=production
PORT=3001

# ---- Database (PostgreSQL) ----
# Managed by Dokploy — set the real URL in the panel, do not hard-code here.
DATABASE_URL=postgresql://patacerta:REPLACE_ME@patacerta-postgres-stage:5432/patacerta?schema=public

# ---- JWT ----
# Generate a strong random secret per environment:
#   openssl rand -base64 48
JWT_SECRET=REPLACE_ME_STAGE_JWT_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REPLACE_ME_STAGE_JWT_REFRESH_SECRET
JWT_REFRESH_EXPIRES_IN=7d

# ---- MinIO (S3-compatible storage) ----
MINIO_ENDPOINT=patacerta-minio-stage
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=REPLACE_ME
MINIO_SECRET_KEY=REPLACE_ME
MINIO_BUCKET=patacerta-uploads-stage

# ---- Admin Seed ----
ADMIN_EMAIL=admin@patacerta.pt
ADMIN_PASSWORD=REPLACE_ME_STRONG_PASSWORD

# ---- Auth (stage convenience) ----
# Bypass email verification in stage so testers can register and log in
# without SMTP. NEVER enable this in production.
AUTH_SKIP_EMAIL_VERIFICATION=true

# ---- URLs ----
FRONTEND_URL=https://stage.patacerta.pt
CORS_ORIGIN=https://stage.patacerta.pt

# ---- Frontend build-time ----
VITE_API_URL=https://stage.patacerta.pt/api
