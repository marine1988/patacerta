# ============================================
# PataCerta — STAGE Environment Variables
# Copy to .env.stage in Dokploy and fill real secrets.
# DO NOT commit the real .env.stage — only this example.
# ============================================

# ---- General ----
# IMPORTANTE: stage usa NODE_ENV=stage (nao production).
# - 'stage' faz HTTPS/cookies Secure/HSTS via isHttps em apps/api/src/lib/env.ts
# - 'stage' nao dispara fail-fasts de prod (AUTH_SKIP_EMAIL_VERIFICATION,
#   DISABLE_RATE_LIMITS, SMTP obrigatorio).
# Definir 'production' aqui faria o boot abortar porque temos
# AUTH_SKIP_EMAIL_VERIFICATION=true e SMTP nao configurado.
NODE_ENV=stage
PORT=3001

# ---- Database (PostgreSQL) ----
# Managed by Dokploy — set the real URL in the panel, do not hard-code here.
DATABASE_URL=postgresql://patacerta:REPLACE_ME@patacerta-postgres-stage:5432/patacerta?schema=public

# ---- JWT ----
# Generate a strong random secret per environment:
#   openssl rand -base64 48
JWT_SECRET=REPLACE_ME_STAGE_JWT_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REPLACE_ME_STAGE_JWT_REFRESH_SECRET
JWT_REFRESH_EXPIRES_IN=7d

# ---- MinIO (S3-compatible storage) ----
MINIO_ENDPOINT=patacerta-minio-stage
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=REPLACE_ME
MINIO_SECRET_KEY=REPLACE_ME
MINIO_BUCKET=patacerta-uploads-stage

# ---- Admin Seed ----
ADMIN_EMAIL=admin@patacerta.pt
ADMIN_PASSWORD=REPLACE_ME_STRONG_PASSWORD

# ---- Auth (stage convenience) ----
# Bypass email verification in stage so testers can register and log in
# without SMTP. NEVER enable this in production.
AUTH_SKIP_EMAIL_VERIFICATION=true

# ---- Rate limiting ----
# Disable rate limits in stage so testers don't hit 429 during smoke tests.
# NEVER enable this in production.
DISABLE_RATE_LIMITS=true

# ---- Geocoding (Nominatim / OpenStreetMap) ----
# NOMINATIM_EMAIL is required by the OSM Nominatim usage policy and is
# included in the User-Agent header. Use a real contact per environment.
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_EMAIL=stage@patacerta.pt

# ---- URLs ----
FRONTEND_URL=https://stage.patacerta.pt
CORS_ORIGIN=https://stage.patacerta.pt

# ---- Frontend build-time ----
VITE_API_URL=https://stage.patacerta.pt/api

# ---- AdSense (Google Ads) ----
# Em stage mantém-se OFF — só queremos servir ads no domínio
# de produção aprovado pelo Google. Ver docs/ADSENSE_SETUP.md.
VITE_ADSENSE_CLIENT_ID=
VITE_ADSENSE_ENABLED=false

# ---- Stripe (Pagamentos) ----
# Em stage usar SEMPRE chaves de teste (sk_test_..., pk_test_...).
# Webhook em https://dashboard.stripe.com/test/webhooks apontando para
# https://stage.patacerta.pt/api/webhooks/stripe.
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ---- SMTP (emails transacionais) ----
# Em stage podemos arrancar sem SMTP porque AUTH_SKIP_EMAIL_VERIFICATION=true
# faz com que registos passem direct sem precisar de email verificado.
# Em prod, SMTP_HOST e' obrigatorio (fail-fast). Provider recomendado:
# Mailgun EU (smtp.eu.mailgun.org). Ver header do docker-compose.dokploy.yml
# para setup completo (SPF/DKIM, criar SMTP user, etc).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Patacerta <noreply@patacerta.pt>
