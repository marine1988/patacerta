generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---- Enums ----

enum UserRole {
  OWNER
  BREEDER
  SERVICE_PROVIDER
  ADMIN
}

enum BreederStatus {
  DRAFT
  PENDING_VERIFICATION
  VERIFIED
  SUSPENDED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocType {
  NIF
  DGAV
  CARTAO_CIDADAO
  CITES
  OTHER
}

enum ReviewStatus {
  PUBLISHED
  HIDDEN
  FLAGGED
}

enum ServiceStatus {
  DRAFT
  ACTIVE
  PAUSED
  SUSPENDED
}

enum PriceUnit {
  FIXED
  HOURLY
  PER_SESSION
}

enum ServiceReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

// ---- Models ----

model User {
  id                         Int       @id @default(autoincrement())
  email                      String    @unique @db.VarChar(255)
  passwordHash               String    @map("password_hash") @db.VarChar(255)
  firstName                  String    @map("first_name") @db.VarChar(100)
  lastName                   String    @map("last_name") @db.VarChar(100)
  role                       UserRole  @default(OWNER)
  phone                      String?   @db.VarChar(20)
  avatarUrl                  String?   @map("avatar_url") @db.VarChar(512)
  isActive                   Boolean   @default(true) @map("is_active")
  suspendedAt                DateTime? @map("suspended_at")
  suspendedReason            String?   @map("suspended_reason") @db.VarChar(500)
  resetToken                 String?   @unique @map("reset_token") @db.VarChar(64)
  resetTokenExpiresAt        DateTime? @map("reset_token_expires_at")
  emailVerified              Boolean   @default(false) @map("email_verified")
  emailVerificationToken     String?   @unique @map("email_verification_token") @db.VarChar(64)
  emailVerificationExpiresAt DateTime? @map("email_verification_expires_at")
  createdAt                  DateTime  @default(now()) @map("created_at")
  updatedAt                  DateTime  @updatedAt @map("updated_at")

  breeder                Breeder?
  sentMessages           Message[]         @relation("sender")
  threadsAsOwner         Thread[]          @relation("thread_owner")
  reviewedDocs           VerificationDoc[] @relation("reviewer")
  reviews                Review[]          @relation("review_author")
  reviewFlags            ReviewFlag[]      @relation("review_flag_reporter")
  serviceReviews         ServiceReview[]   @relation("service_review_author")
  serviceReviewFlags     ServiceReviewFlag[] @relation("service_review_flag_reporter")
  messageReportsFiled    MessageReport[]   @relation("message_report_reporter")
  messageReportsReviewed MessageReport[]   @relation("message_report_reviewer")
  services               Service[]         @relation("service_provider")
  serviceReportsFiled    ServiceReport[]   @relation("service_report_reporter")
  serviceReportsReviewed ServiceReport[]   @relation("service_report_reviewer")
  auditLogs              AuditLog[]
  consentLogs            ConsentLog[]
  refreshTokens          RefreshToken[]

  @@map("users")
}

model Breeder {
  id             Int           @id @default(autoincrement())
  userId         Int           @unique @map("user_id")
  businessName   String        @map("business_name") @db.VarChar(200)
  nif            String        @unique @db.VarChar(9)
  dgavNumber     String        @unique @map("dgav_number") @db.VarChar(50)
  description    String?       @db.Text
  website        String?       @db.VarChar(255)
  phone          String?       @db.VarChar(20)
  status         BreederStatus @default(DRAFT)
  verifiedAt     DateTime?     @map("verified_at")
  suspendedAt    DateTime?     @map("suspended_at")
  suspendedReason String?      @map("suspended_reason") @db.VarChar(500)
  featuredUntil  DateTime?     @map("featured_until")
  districtId     Int           @map("district_id")
  municipalityId Int           @map("municipality_id")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  // Apresentacao publica adicional
  youtubeVideoId String? @map("youtube_video_id") @db.VarChar(20)

  // Reconhecimentos oficiais
  cpcMember     Boolean @default(false) @map("cpc_member")
  fciAffiliated Boolean @default(false) @map("fci_affiliated")

  // Sao incluidos com cada cachorro
  vetCheckup      Boolean @default(false) @map("incl_vet_checkup")
  microchip       Boolean @default(false) @map("incl_microchip")
  vaccinations    Boolean @default(false) @map("incl_vaccinations")
  lopRegistry     Boolean @default(false) @map("incl_lop")
  kennelName      Boolean @default(false) @map("incl_kennel_name")
  salesInvoice    Boolean @default(false) @map("incl_sales_invoice")
  food            Boolean @default(false) @map("incl_food")
  initialTraining Boolean @default(false) @map("incl_initial_training")

  // Recolha
  pickupInPerson  Boolean @default(true) @map("pickup_in_person")
  deliveryByCar   Boolean @default(false) @map("delivery_by_car")
  deliveryByPlane Boolean @default(false) @map("delivery_by_plane")
  pickupNotes     String? @map("pickup_notes") @db.Text

  // Raças que o criador trabalha (cataloga em BreederBreed) +
  // texto livre opcional para raças que nao constam do catalogo
  // ("Outras"). O constraint de "pelo menos 1 raça do catalogo
  // OU otherBreedsNote preenchida" e validado a nivel API.
  otherBreedsNote String? @map("other_breeds_note") @db.VarChar(500)

  // Agregados desnormalizados (mantidos via recomputeBreederRating em
  // services/breeder-stats.ts). Evita groupBy/aggregation repetida em
  // todos os endpoints de listagem (search, home/featured, mapa).
  // Recalculados sempre que uma Review e' criada/editada/apagada ou
  // muda de status (DRAFT/PUBLISHED/HIDDEN).
  avgRating   Float? @map("avg_rating")
  reviewCount Int    @default(0) @map("review_count")

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  district         District          @relation(fields: [districtId], references: [id])
  municipality     Municipality      @relation(fields: [municipalityId], references: [id])
  species          BreederSpecies[]
  breeds           BreederBreed[]
  verificationDocs VerificationDoc[]
  reviews          Review[]          @relation("reviewed_breeder")
  threadsAsBreeder Thread[]          @relation("thread_breeder")
  photos           BreederPhoto[]
  sponsoredSlots   SponsoredBreedSlot[]

  @@index([districtId])
  @@index([status])
  @@index([nif])
  @@index([dgavNumber])
  @@index([featuredUntil])
  // Compostos para hot-paths publicos (search/map/home featured).
  // Filtros tipicos: status='VERIFIED' AND (districtId|municipalityId|featuredUntil>now).
  // Alinha com pattern ja usado em Service.
  @@index([status, districtId])
  @@index([status, municipalityId])
  @@index([status, featuredUntil])
  @@map("breeders")
}

model Species {
  id       Int    @id @default(autoincrement())
  nameSlug String @unique @map("name_slug") @db.VarChar(50)
  namePt   String @map("name_pt") @db.VarChar(100)

  breeders BreederSpecies[]
  breeds   Breed[]

  @@map("species")
}

// ─── Breed ──────────────────────────────────────────────────────────
//
// Catálogo editorial de raças usado pelo simulador "encontrar a raça
// ideal". Os atributos numéricos usam a escala 1-5 (1 = baixíssimo,
// 5 = altíssimo), os booleanos são auto-explicativos. Os campos size,
// coatLength e barkLevel usam enums string para legibilidade.
//
// Os valores são fontes editoriais nossas (inspiradas em FCI / Purina
// / AKC / Wikipedia pt) — ver apps/api/prisma/seed-breeds.ts.
model Breed {
  id          Int    @id @default(autoincrement())
  speciesId   Int    @map("species_id")
  nameSlug    String @unique @map("name_slug") @db.VarChar(80)
  namePt      String @map("name_pt") @db.VarChar(120)
  fciGroup    String? @map("fci_group") @db.VarChar(80)
  origin      String? @db.VarChar(120)
  summaryPt   String  @map("summary_pt") @db.VarChar(500)

  // ─ Atributos físicos ─
  size            String @db.VarChar(10)    // "small" | "medium" | "large" | "giant"
  weightMinKg     Float  @map("weight_min_kg")
  weightMaxKg     Float  @map("weight_max_kg")
  lifespanMinYrs  Int    @map("lifespan_min_yrs")
  lifespanMaxYrs  Int    @map("lifespan_max_yrs")
  coatLength      String @map("coat_length") @db.VarChar(10) // "short" | "medium" | "long"
  shedding        Int    // 1-5
  hypoallergenic  Boolean @default(false)

  // ─ Necessidades / temperamento ─
  energyLevel       Int @map("energy_level")        // 1-5
  exerciseDailyMin  Int @map("exercise_daily_min")  // minutos por dia
  trainability      Int                              // 1-5
  barkLevel         String @map("bark_level") @db.VarChar(10) // "low" | "medium" | "high"
  groomingLevel     Int @map("grooming_level")     // 1-5

  // ─ Compatibilidades ─
  goodWithKids      Int @map("good_with_kids")      // 1-5
  goodWithDogs      Int @map("good_with_dogs")      // 1-5
  goodWithStrangers Int @map("good_with_strangers") // 1-5
  apartmentFriendly Boolean @default(false) @map("apartment_friendly")
  noviceFriendly    Boolean @default(false) @map("novice_friendly")
  toleratesAlone    Int @map("tolerates_alone")     // 1-5

  // ─ Ambiente ─
  coldTolerance     Int @map("cold_tolerance")      // 1-5
  heatTolerance     Int @map("heat_tolerance")      // 1-5

  // ─ Imagem ilustrativa (opcional) ─
  imageUrl   String? @map("image_url") @db.VarChar(500)

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  species Species @relation(fields: [speciesId], references: [id], onDelete: Cascade)
  breeders BreederBreed[]
  sponsoredSlots SponsoredBreedSlot[]

  @@index([speciesId])
  @@index([size])
  @@map("breeds")
}

model BreederBreed {
  breederId Int @map("breeder_id")
  breedId   Int @map("breed_id")

  breeder Breeder @relation(fields: [breederId], references: [id], onDelete: Cascade)
  breed   Breed   @relation(fields: [breedId], references: [id], onDelete: Cascade)

  @@id([breederId, breedId])
  @@index([breedId])
  @@map("breeder_breeds")
}

// ─── SponsoredBreedSlot ─────────────────────────────────────────────
//
// Slot patrocinado de um criador para uma raça específica.
// Aparece nos cards de resultado do simulador (`breed-matcher`) com
// label "Patrocinado" obrigatório (ver UI). MVP: máximo 3 slots
// activos por raça em simultâneo (limite imposto no controller, não
// no schema, para permitir overlap durante migração de campanhas).
//
// status:
//   ACTIVE     — dentro da janela [startsAt, endsAt] e a aparecer
//   PAUSED     — admin pausou manualmente
//   EXPIRED    — fora da janela (calculado, mas pode ficar persistido)
//
// Tracking: impressionCount/clickCount são incrementados com
// updateMany e contadores best-effort (não-transaccional, P2 OK).
model SponsoredBreedSlot {
  id              Int                      @id @default(autoincrement())
  breederId       Int                      @map("breeder_id")
  breedId         Int                      @map("breed_id")
  startsAt        DateTime                 @map("starts_at")
  endsAt          DateTime                 @map("ends_at")
  status          SponsoredBreedSlotStatus @default(ACTIVE)
  impressionCount Int                      @default(0) @map("impression_count")
  clickCount      Int                      @default(0) @map("click_count")
  notes           String?                  @db.VarChar(500)
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")

  breeder Breeder @relation(fields: [breederId], references: [id], onDelete: Cascade)
  breed   Breed   @relation(fields: [breedId], references: [id], onDelete: Cascade)

  @@index([breedId, status, startsAt, endsAt])
  @@index([breederId])
  @@map("sponsored_breed_slots")
}

enum SponsoredBreedSlotStatus {
  ACTIVE
  PAUSED
  EXPIRED
}

model BreederSpecies {
  breederId Int @map("breeder_id")
  speciesId Int @map("species_id")

  breeder Breeder @relation(fields: [breederId], references: [id], onDelete: Cascade)
  species Species @relation(fields: [speciesId], references: [id], onDelete: Cascade)

  @@id([breederId, speciesId])
  @@map("breeder_species")
}

model District {
  id        Int    @id @default(autoincrement())
  code      String @unique @db.VarChar(5)
  namePt    String @map("name_pt") @db.VarChar(100)
  latitude  Float?
  longitude Float?

  municipalities Municipality[]
  breeders       Breeder[]
  services       Service[]

  @@map("districts")
}

model Municipality {
  id         Int    @id @default(autoincrement())
  districtId Int    @map("district_id")
  code       String @unique @db.VarChar(10)
  namePt     String @map("name_pt") @db.VarChar(100)

  district        District          @relation(fields: [districtId], references: [id], onDelete: Cascade)
  breeders        Breeder[]
  services        Service[]
  serviceCoverage ServiceCoverage[]

  @@index([districtId])
  @@map("municipalities")
}

model VerificationDoc {
  id         Int                @id @default(autoincrement())
  breederId  Int                @map("breeder_id")
  docType    DocType            @map("doc_type")
  fileUrl    String             @map("file_url") @db.VarChar(512)
  fileName   String             @map("file_name") @db.VarChar(255)
  status     VerificationStatus @default(PENDING)
  notes      String?            @db.Text
  reviewedBy Int?               @map("reviewed_by")
  reviewedAt DateTime?          @map("reviewed_at")
  createdAt  DateTime           @default(now()) @map("created_at")

  breeder  Breeder @relation(fields: [breederId], references: [id], onDelete: Cascade)
  reviewer User?   @relation("reviewer", fields: [reviewedBy], references: [id])

  @@index([breederId])
  @@index([status])
  @@map("verification_docs")
}

model Thread {
  id        Int      @id @default(autoincrement())
  ownerId   Int      @map("owner_id")
  breederId Int?     @map("breeder_id")
  serviceId Int?     @map("service_id")
  subject   String   @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  archivedByOwnerAt   DateTime? @map("archived_by_owner_at")
  archivedByBreederAt DateTime? @map("archived_by_breeder_at")

  owner    User      @relation("thread_owner", fields: [ownerId], references: [id], onDelete: Cascade)
  breeder  Breeder?  @relation("thread_breeder", fields: [breederId], references: [id], onDelete: Cascade)
  service  Service?  @relation("thread_service", fields: [serviceId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([ownerId, breederId])
  @@unique([ownerId, serviceId])
  @@index([ownerId])
  @@index([breederId])
  @@index([serviceId])
  @@index([updatedAt])
  @@map("threads")
}

model Message {
  id        Int       @id @default(autoincrement())
  threadId  Int       @map("thread_id")
  senderId  Int       @map("sender_id")
  body      String    @db.Text
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  editedAt  DateTime? @map("edited_at")
  deletedAt DateTime? @map("deleted_at")
  deletedBy Int?      @map("deleted_by")

  thread  Thread          @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender  User            @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)
  reports MessageReport[]

  @@index([threadId])
  @@index([senderId])
  @@index([threadId, createdAt])
  @@index([threadId, senderId, readAt])
  @@map("messages")
}

model MessageReport {
  id         Int                 @id @default(autoincrement())
  messageId  Int                 @map("message_id")
  reporterId Int                 @map("reporter_id")
  reason     String              @db.VarChar(500)
  status     MessageReportStatus @default(PENDING)
  createdAt  DateTime            @default(now()) @map("created_at")
  reviewedBy Int?                @map("reviewed_by")
  reviewedAt DateTime?           @map("reviewed_at")
  resolution String?             @db.VarChar(500)

  message  Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  reporter User    @relation("message_report_reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewer User?   @relation("message_report_reviewer", fields: [reviewedBy], references: [id])

  @@index([messageId])
  @@index([reporterId])
  @@index([status])
  @@map("message_reports")
}

enum MessageReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model Review {
  id               Int          @id @default(autoincrement())
  breederId        Int          @map("breeder_id")
  authorId         Int          @map("author_id")
  rating           Int          @db.SmallInt
  title            String       @db.VarChar(200)
  body             String?      @db.Text
  status           ReviewStatus @default(PUBLISHED)
  moderationReason String?      @map("moderation_reason") @db.Text
  reply            String?      @db.Text
  repliedAt        DateTime?    @map("replied_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  breeder Breeder      @relation("reviewed_breeder", fields: [breederId], references: [id], onDelete: Cascade)
  author  User         @relation("review_author", fields: [authorId], references: [id], onDelete: Cascade)
  flags   ReviewFlag[]

  @@unique([breederId, authorId])
  @@index([breederId])
  @@index([authorId])
  @@index([status])
  @@index([breederId, status, createdAt])
  @@map("reviews")
}

model ReviewFlag {
  id         Int      @id @default(autoincrement())
  reviewId   Int      @map("review_id")
  reporterId Int      @map("reporter_id")
  reason     String   @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reporter User   @relation("review_flag_reporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([reviewId, reporterId])
  @@index([reviewId])
  @@index([reporterId])
  @@map("review_flags")
}

model ServiceReview {
  id               Int          @id @default(autoincrement())
  serviceId        Int          @map("service_id")
  authorId         Int          @map("author_id")
  rating           Int          @db.SmallInt
  title            String       @db.VarChar(200)
  body             String?      @db.Text
  status           ReviewStatus @default(PUBLISHED)
  moderationReason String?      @map("moderation_reason") @db.Text
  reply            String?      @db.Text
  repliedAt        DateTime?    @map("replied_at")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  service Service              @relation("reviewed_service", fields: [serviceId], references: [id], onDelete: Cascade)
  author  User                 @relation("service_review_author", fields: [authorId], references: [id], onDelete: Cascade)
  flags   ServiceReviewFlag[]

  @@unique([serviceId, authorId])
  @@index([serviceId])
  @@index([authorId])
  @@index([status])
  @@index([serviceId, status, createdAt])
  @@map("service_reviews")
}

model ServiceReviewFlag {
  id         Int      @id @default(autoincrement())
  reviewId   Int      @map("review_id")
  reporterId Int      @map("reporter_id")
  reason     String   @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at")

  review   ServiceReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reporter User          @relation("service_review_flag_reporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([reviewId, reporterId])
  @@index([reviewId])
  @@index([reporterId])
  @@map("service_review_flags")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  action    String   @db.VarChar(50)
  entity    String   @db.VarChar(50)
  entityId  Int?     @map("entity_id")
  details   String?  @db.Text
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ConsentLog {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  consentType String   @map("consent_type") @db.VarChar(50)
  granted     Boolean
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  userAgent   String?  @map("user_agent") @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([consentType])
  @@map("consent_logs")
}

// Refresh-token store. We persist a SHA-256 hash of every issued refresh
// token so we can rotate them on use, revoke them on logout, and detect
// reuse (a sign of token theft). The plaintext token is never written to
// disk; clients hold it client-side and present it on /auth/refresh.
model RefreshToken {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  tokenHash    String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt    DateTime  @map("expires_at")
  revokedAt    DateTime? @map("revoked_at")
  // When this token is rotated, we point at the replacement so we can walk
  // the chain and revoke siblings if the same token is replayed.
  replacedById Int?      @map("replaced_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  ipAddress    String?   @map("ip_address") @db.VarChar(45)
  userAgent    String?   @map("user_agent") @db.VarChar(500)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ---- Services (dog-walking, dog-sitting, ...) ----

model ServiceCategory {
  id       Int     @id @default(autoincrement())
  nameSlug String  @unique @map("name_slug") @db.VarChar(50)
  namePt   String  @map("name_pt") @db.VarChar(100)
  isActive Boolean @default(false) @map("is_active")

  services Service[]

  @@map("service_categories")
}

model Service {
  id              Int           @id @default(autoincrement())
  providerId      Int           @map("provider_id")
  categoryId      Int           @map("category_id")
  title           String        @db.VarChar(200)
  description     String        @db.Text
  priceCents      Int           @map("price_cents")
  priceUnit       PriceUnit     @map("price_unit")
  currency        String        @default("EUR") @db.VarChar(3)
  districtId      Int           @map("district_id")
  municipalityId  Int           @map("municipality_id")
  addressLine     String?       @map("address_line") @db.VarChar(255)
  latitude        Float?
  longitude       Float?
  geocodedAt      DateTime?     @map("geocoded_at")
  geocodeSource   String?       @map("geocode_source") @db.VarChar(20)
  serviceRadiusKm Int?          @map("service_radius_km")
  status          ServiceStatus @default(DRAFT)
  website         String?       @db.VarChar(255)
  phone           String?       @db.VarChar(20)

  avgRating   Decimal @default(0) @map("avg_rating") @db.Decimal(3, 2)
  reviewCount Int     @default(0) @map("review_count")

  publishedAt   DateTime? @map("published_at")
  removedAt     DateTime? @map("removed_at")
  removedReason String?   @map("removed_reason") @db.VarChar(500)
  featuredUntil DateTime? @map("featured_until")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  provider      User              @relation("service_provider", fields: [providerId], references: [id], onDelete: Cascade)
  category      ServiceCategory   @relation(fields: [categoryId], references: [id])
  district      District          @relation(fields: [districtId], references: [id])
  municipality  Municipality      @relation(fields: [municipalityId], references: [id])
  photos        ServicePhoto[]
  coverageAreas ServiceCoverage[]
  reports       ServiceReport[]
  reviews       ServiceReview[]   @relation("reviewed_service")
  threads       Thread[]          @relation("thread_service")

  @@index([providerId])
  @@index([categoryId])
  @@index([districtId])
  @@index([status])
  @@index([status, categoryId])
  @@index([status, categoryId, districtId])
  // Compostos adicionais para os orderBy/filtros mais frequentes do catalogo publico.
  // Cada um cobre uma combinacao real observada em listServices/mapServices.
  @@index([status, publishedAt(sort: Desc)])
  @@index([status, priceCents])
  @@index([status, avgRating(sort: Desc)])
  @@index([status, municipalityId])
  @@index([status, latitude, longitude])
  @@index([providerId, updatedAt(sort: Desc)])
  @@index([featuredUntil])
  @@map("services")
}

model ServicePhoto {
  id        Int      @id @default(autoincrement())
  serviceId Int      @map("service_id")
  url       String   @db.VarChar(512)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, sortOrder])
  @@map("service_photos")
}

model BreederPhoto {
  id        Int      @id @default(autoincrement())
  breederId Int      @map("breeder_id")
  url       String   @db.VarChar(512)
  caption   String?  @db.VarChar(200)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  breeder Breeder @relation(fields: [breederId], references: [id], onDelete: Cascade)

  @@index([breederId, sortOrder])
  @@map("breeder_photos")
}

model ServiceCoverage {
  serviceId      Int @map("service_id")
  municipalityId Int @map("municipality_id")

  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  municipality Municipality @relation(fields: [municipalityId], references: [id])

  @@id([serviceId, municipalityId])
  @@index([municipalityId])
  @@map("service_coverage")
}

model ServiceReport {
  id         Int                 @id @default(autoincrement())
  serviceId  Int                 @map("service_id")
  reporterId Int                 @map("reporter_id")
  reason     String              @db.VarChar(500)
  status     ServiceReportStatus @default(PENDING)
  createdAt  DateTime            @default(now()) @map("created_at")
  reviewedBy Int?                @map("reviewed_by")
  reviewedAt DateTime?           @map("reviewed_at")
  resolution String?             @db.VarChar(500)

  service  Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  reporter User    @relation("service_report_reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewer User?   @relation("service_report_reviewer", fields: [reviewedBy], references: [id])

  // Garante dedupe de denuncias PENDING do mesmo autor contra o mesmo
  // servico ao nivel da DB (elimina a race condition em reportService).
  @@unique([serviceId, reporterId, status], name: "service_report_dedupe")
  @@index([serviceId])
  @@index([reporterId])
  @@index([status])
  @@map("service_reports")
}
