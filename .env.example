# ============================================
# PataCerta — Environment Variables
# Copy to .env and fill in real values
# ============================================

# ---- General ----
NODE_ENV=development
PORT=3001

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://patacerta:patacerta_dev@localhost:5432/patacerta?schema=public

# ---- JWT ----
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# ---- MinIO (S3-compatible storage) ----
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=patacerta_minio
MINIO_SECRET_KEY=patacerta_minio_secret
MINIO_BUCKET=patacerta-uploads

# ---- Admin Seed ----
ADMIN_EMAIL=admin@patacerta.pt
ADMIN_PASSWORD=AdminPass123!

# ---- Auth ----
# Set to 'true' only in dev/stage. Bypasses email verification on register and
# login. MUST be false/unset in production.
AUTH_SKIP_EMAIL_VERIFICATION=false

# ---- Rate limiting ----
# Set to 'true' only in dev/stage to make all rate limiters no-ops.
# MUST be false/unset in production.
DISABLE_RATE_LIMITS=false

# ---- Geocoding (Nominatim / OpenStreetMap) ----
# Used by the Services module to resolve service addresses to lat/lng.
# Best-effort: falls back to the district centroid when Nominatim is
# unreachable or returns no match.
# NOMINATIM_EMAIL is REQUIRED by the OSM Nominatim usage policy and is
# sent in the User-Agent header. Use a real contact address per environment.
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_EMAIL=dev@patacerta.pt

# ---- Frontend ----
VITE_API_URL=http://localhost:3001/api
