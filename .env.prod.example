# ============================================
# PataCerta — PRODUCTION Environment Variables
# ============================================
# Copy these to Dokploy > Environment (do NOT commit real secrets).
# This is a reference template only.
#
# Required secrets marked with [REQUIRED]
# Optional with defaults marked with [OPTIONAL]
# ============================================

# ---- General ----
# MUST be 'production' for fail-safes to activate
NODE_ENV=production
PORT=3001

# ---- Database (PostgreSQL) [REQUIRED] ----
# Managed by Dokploy — connection pool tuned for container env
DATABASE_URL=postgresql://patacerta:REPLACE_ME@postgres:5432/patacerta?schema=public&pool_timeout=20&connection_limit=5

# ---- JWT [REQUIRED] ----
# Generate strong secrets: openssl rand -base64 48
JWT_SECRET=REPLACE_ME_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REPLACE_ME_64_CHAR_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=7d

# ---- MinIO (S3-compatible storage) [REQUIRED] ----
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=REPLACE_ME_STRONG_PASSWORD
MINIO_BUCKET=patacerta-uploads

# ---- Admin Seed [REQUIRED] ----
ADMIN_EMAIL=admin@patacerta.pt
ADMIN_PASSWORD=REPLACE_ME_STRONG_PASSWORD

# ---- Auth (production: MUST be false) ----
# WARNING: API will REFUSE to start if these are true in production!
AUTH_SKIP_EMAIL_VERIFICATION=false
DISABLE_RATE_LIMITS=false

# ---- Email (Resend) [REQUIRED] ----
# https://resend.com — 100 emails/day free, EU region available
RESEND_API_KEY=re_REPLACE_ME
FROM_EMAIL=noreply@patacerta.pt

# ---- SMTP (Alternative to Resend) [REQUIRED if using Mailgun] ----
# Provider: Mailgun EU (smtp.eu.mailgun.org)
# Setup DNS: SPF, DKIM per Mailgun instructions
SMTP_HOST=smtp.eu.mailgun.org
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=postmaster@mg.patacerta.pt
SMTP_PASS=REPLACE_ME
SMTP_FROM=Patacerta <noreply@patacerta.pt>

# Escape hatch (NOT RECOMMENDED): Set to 1 to allow boot without SMTP
# Emails will only be logged, not sent. Use only for emergency debugging.
# ALLOW_NO_SMTP_IN_PROD=1

# ---- URLs [REQUIRED] ----
FRONTEND_URL=https://patacerta.pt
CORS_ORIGIN=https://patacerta.pt
PUBLIC_URL=https://patacerta.pt

# ---- Frontend build-time (Vite) [REQUIRED] ----
# These are build-args in docker-compose, not runtime env vars
VITE_API_URL=https://patacerta.pt/api
VITE_PUBLIC_URL=https://patacerta.pt

# ---- Geocoding (Nominatim / OpenStreetMap) [OPTIONAL] ----
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_EMAIL=admin@patacerta.pt

# ---- AdSense (Google Ads) [OPTIONAL] ----
# Only enable after Google approval. See docs/ADSENSE_SETUP.md
VITE_ADSENSE_CLIENT_ID=
VITE_ADSENSE_ENABLED=false

# ---- Stripe (Payments) [REQUIRED for monetization] ----
# Live keys from https://dashboard.stripe.com/apikeys
# NEVER use test keys (sk_test_/pk_test_) in production!
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME

# Webhook signing secret from https://dashboard.stripe.com/webhooks
# Endpoint URL: https://patacerta.pt/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ---- Backups (encrypted with age) [REQUIRED] ----
# Generate key OFFLINE: age-keygen -o ~/patacerta-backup-key.txt
# Extract public key (age1...) and store private key OFFLINE (USB/1Password)
# WARNING: If you lose the private key, backups are UNRECOVERABLE
AGE_RECIPIENT=age1REPLACE_ME_WITH_PUBLIC_KEY

# MinIO bucket for backups (created automatically)
MINIO_BACKUP_BUCKET=patacerta-backups

# ---- Healthchecks.io (dead-man-switch) [RECOMMENDED] ----
# Create 3 checks at https://healthchecks.io (free tier: 20 checks)
# Period: 1 day, Grace: 2 hours, Notifications: email/Slack
HEALTHCHECKS_URL_BACKUP=https://hc-ping.com/REPLACE_ME
HEALTHCHECKS_URL_BACKUP_MINIO=https://hc-ping.com/REPLACE_ME
HEALTHCHECKS_URL_ROTATE=https://hc-ping.com/REPLACE_ME

# ---- Backup Retention (GFS policy) [OPTIONAL] ----
# Defaults are sensible for most use cases
RETENTION_DAILY=7
RETENTION_WEEKLY=4
RETENTION_MONTHLY=6

# ---- SEO (production) ----
# Leave ROBOTS_HEADER empty in production (allows indexing)
# In stage: add_header X-Robots-Tag "noindex, nofollow" always;
ROBOTS_HEADER=

# ---- Boot flags (production: MUST be false) ----
# These are for dev/stage only. NEVER enable in production.
RESET_DB_ON_BOOT=false
RUN_SEED_ON_BOOT=false
RUN_SEED_DEMO_ON_BOOT=false
SEED_INCLUDE_DEMO=false
USE_DB_PUSH=false

# ============================================
# CHECKLIST BEFORE DEPLOYING TO PRODUCTION:
# ============================================
# [ ] Generated JWT_SECRET and JWT_REFRESH_SECRET (openssl rand -base64 48)
# [ ] Generated MINIO_SECRET_KEY (strong random password)
# [ ] Generated ADMIN_PASSWORD (min 8 chars, upper+lower+number)
# [ ] Generated AGE_RECIPIENT (age-keygen, stored private key OFFLINE)
# [ ] Configured Resend/SMTP (tested email delivery)
# [ ] Configured Stripe live keys (tested webhook delivery)
# [ ] Created Healthchecks.io checks (3 URLs)
# [ ] Verified AUTH_SKIP_EMAIL_VERIFICATION=false
# [ ] Verified DISABLE_RATE_LIMITS=false
# [ ] Verified all REPLACE_ME placeholders are filled
# [ ] Tested stage deployment first
# ============================================
