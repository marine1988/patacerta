{
  "name": "patacerta",
  "version": "0.1.0",
  "private": true,
  "description": "PataCerta — verified pet breeders platform (Portugal).",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "dev:api": "pnpm --filter @patacerta/api dev",
    "dev:web": "pnpm --filter @patacerta/web dev",
    "build": "pnpm -r --filter \"./apps/*\" build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "test": "pnpm -r test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "db:migrate": "pnpm --filter @patacerta/api db:migrate",
    "db:seed": "pnpm --filter @patacerta/api db:seed",
    "db:studio": "pnpm --filter @patacerta/api db:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  }
}
